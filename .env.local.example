# Copy this file to .env for local HTTP setup.
# cp .env.local.example .env
# ./n8nite env check

# ====================================================================
# Minimum configuration (required by this docker-compose setup)
# Sources:
# - https://docs.n8n.io/hosting/installation/server-setups/docker-compose/
# - https://docs.n8n.io/hosting/configuration/environment-variables/
# ====================================================================

# Local n8n URL (docker-compose maps host port 5678 -> container 5678)
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Runtime defaults
NODE_ENV=production
# Prefer a valid IANA timezone (for example: Africa/Algiers, Europe/Paris, UTC)
GENERIC_TIMEZONE=UTC
# Required so main + worker can decrypt the same credentials.
# Keep this stable for a given deployment.
# Tip: generate quickly with ./n8nite env keygen --write --force
N8N_ENCRYPTION_KEY=local_dev_only_n8n_encryption_key_123456

# Postgres bootstrap credentials
POSTGRES_USER=n8n_admin
POSTGRES_PASSWORD=n8n_admin_password
POSTGRES_DB=n8n

# Postgres app credentials used by n8n
POSTGRES_NON_ROOT_USER=n8n_user
POSTGRES_NON_ROOT_PASSWORD=n8n_user_password

# ====================================================================
# n8n-specific optional/custom settings
# Docs for all variables:
# https://docs.n8n.io/hosting/configuration/environment-variables/
# ====================================================================

# API base URL for n8n UI
VUE_APP_URL_BASE_API=http://localhost:5678/api

# Override test/tunnel webhook URL (usually same as WEBHOOK_URL on server)
WEBHOOK_TUNNEL_URL=http://localhost:5678/

# Editor URL override (useful when host/proxy path differs)
# N8N_EDITOR_BASE_URL=http://localhost:5678/

# Encryption and security
# N8N_SECURE_COOKIE=false
# N8N_BLOCK_ENV_ACCESS_IN_NODE=true
# N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true

# Execution retention/timeouts
# EXECUTIONS_DATA_PRUNE=true
# EXECUTIONS_DATA_MAX_AGE=336
# EXECUTIONS_DATA_PRUNE_MAX_COUNT=10000
# EXECUTIONS_TIMEOUT=3600
# EXECUTIONS_TIMEOUT_MAX=7200

# Queue/worker tuning for this compose stack
# OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
# QUEUE_BULL_REDIS_DB=0
# N8N_WORKER_CONCURRENCY=10

# Reverse-proxy realtime transport
# N8N_PUSH_BACKEND=websocket
