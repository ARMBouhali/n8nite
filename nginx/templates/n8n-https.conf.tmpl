# n8n reverse proxy (HTTPS with SSL certificates)
# This file is generated from template placeholders.

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream n8n_upstream {
    server ${UPSTREAM};
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name ${SERVER_NAME};
    return 301 https://$host$request_uri; # managed by Certbot
}

server {
    listen 443 ssl; # managed by Certbot
    listen [::]:443 ssl; # managed by Certbot
    server_name ${SERVER_NAME};

    ssl_certificate ${SSL_CERT}; # managed by Certbot
    ssl_certificate_key ${SSL_KEY}; # managed by Certbot
    include ${CERTBOT_SSL_OPTIONS}; # managed by Certbot
    ssl_dhparam ${CERTBOT_DHPARAM}; # managed by Certbot

    location /rest/push {
        proxy_pass http://n8n_upstream;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_buffering off;
    }

    location / {
        proxy_pass http://n8n_upstream;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
