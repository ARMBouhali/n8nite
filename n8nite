#!/usr/bin/env bash
set -euo pipefail

usage() {
	cat <<'EOF'
Unified entrypoint for this n8n stack.

Usage:
  ./n8nite [global-options] COMMAND [args...]

Global options:
  -v, --version        Show version
  -h, --help           Show this help

Commands:
  deps check [args...]                Check host dependencies (wraps check-deps.sh)
  env check [args...]                 Validate env file (wraps check-env.sh)
  env init [local|prod] [--force]     Create or replace repo .env from template
  env select PATH                     Copy an existing env file into repo .env
  env restore [args...]               Restore env file from a timestamped backup
  env view [args...]                  View env file (less/cat)
  env edit [args...]                  Edit env file (nano preferred, vi fallback)
  env keygen [--write] [--force]      Generate secure N8N_ENCRYPTION_KEY
  uninstall [args...]                 Remove installed n8nite command symlink

  up [compose args...]                Validate env, then docker compose up -d
  down [compose args...]              docker compose down
  start [services...]                 docker compose start
  stop [services...]                  docker compose stop
  restart [services...]               docker compose restart
  logs [services...]                  docker compose logs --tail=200 -f
  ps                                  docker compose ps
  config                              docker compose config
  pull [services...]                  docker compose pull

  nginx generate [args...]            Wrap nginx/generate-nginx-conf.sh
  nginx deploy [args...]              Wrap nginx/install-nginx-and-deploy.sh
  nginx restore [args...]             Wrap nginx/restore-nginx-conf.sh

  interactive | i                     Launch interactive menu
  doctor                              Run env validation + docker compose ps
  test [suite args...]                Run tests/test-n8nite.sh

Examples:
  ./n8nite deps check
  ./n8nite deps check --profile nginx-https
  ./n8nite env init local --force
  ./n8nite env select ./envs/local.env
  ./n8nite env check
  ./n8nite env restore --latest --yes
  ./n8nite env view
  ./n8nite env edit
  ./n8nite env check -n
  ./n8nite env keygen --write --force
  ./n8nite up
  ./n8nite logs n8n
  ./n8nite interactive
  ./n8nite uninstall --yes
  ./n8nite nginx generate -m https -s automation.example.com
  ./n8nite nginx deploy -c n8n-automation -m admin@example.com
  ./n8nite nginx restore -c n8n-automation --latest --yes
  ./n8nite test -f
EOF
}

resolve_script_dir() {
	local source="${BASH_SOURCE[0]}"
	local dir=""

	if command -v readlink >/dev/null 2>&1; then
		while [[ -L "$source" ]]; do
			dir="$(cd -P "$(dirname "$source")" && pwd)"
			source="$(readlink "$source")"
			[[ "$source" != /* ]] && source="$dir/$source"
		done
	fi

	cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
REPO_ROOT="$SCRIPT_DIR"
COMPOSE_FILE="$REPO_ROOT/docker-compose.yml"
ENV_FILE="$REPO_ROOT/.env"

CHECK_ENV_SCRIPT="$REPO_ROOT/check-env.sh"
CHECK_DEPS_SCRIPT="$REPO_ROOT/check-deps.sh"
NGINX_GENERATE_SCRIPT="$REPO_ROOT/nginx/generate-nginx-conf.sh"
NGINX_DEPLOY_SCRIPT="$REPO_ROOT/nginx/install-nginx-and-deploy.sh"
NGINX_RESTORE_SCRIPT="$REPO_ROOT/nginx/restore-nginx-conf.sh"
TEST_SUITE_SCRIPT="$REPO_ROOT/tests/test-n8nite.sh"
ENV_TEMPLATE_PROD="$REPO_ROOT/.env.example"
ENV_TEMPLATE_LOCAL="$REPO_ROOT/.env.local.example"
N8NITE_VERSION="${N8NITE_VERSION:-0.1.0}"

supports_color() {
	if [[ -n "${FORCE_COLOR:-}" && "${FORCE_COLOR}" != "0" ]]; then
		return 0
	fi
	if [[ -n "${CLICOLOR_FORCE:-}" && "${CLICOLOR_FORCE}" != "0" ]]; then
		return 0
	fi
	[[ "${TERM:-}" == "dumb" ]] && return 1
	[[ -t 1 || -t 2 ]]
}

print_banner() {
	local reset="" green=""

	if supports_color; then
		reset=$'\033[0m'
		green=$'\033[38;5;118m'
	fi

	printf '\n'
	printf '%b\n' "${green}            ░██████             ░██   ░██               ${reset}"
	printf '%b\n' "${green}           ░██   ░██                  ░██               ${reset}"
	printf '%b\n' "${green}░████████  ░██   ░██ ░████████  ░██░████████  ░███████  ${reset}"
	printf '%b\n' "${green}░██    ░██  ░██████  ░██    ░██ ░██   ░██    ░██    ░██ ${reset}"
	printf '%b\n' "${green}░██    ░██ ░██   ░██ ░██    ░██ ░██   ░██    ░█████████ ${reset}"
	printf '%b\n' "${green}░██    ░██ ░██   ░██ ░██    ░██ ░██   ░██    ░██        ${reset}"
	printf '%b\n' "${green}░██    ░██  ░██████  ░██    ░██ ░██    ░████  ░███████${reset}"
	printf '\n'
	printf '%b\n' "${green}n8nite :: opinionated n8n stack on wheels${reset}"
	printf '\n'
}

print_version() {
	printf 'n8nite %s\n' "$N8NITE_VERSION"
}

log() {
	local reset="" info=""
	if supports_color; then
		reset=$'\033[0m'
		info=$'\033[38;5;118m'
	fi
	printf '%b[INFO]%b %s\n' "$info" "$reset" "$*"
}

log_warn() {
	local reset="" warn=""
	if supports_color; then
		reset=$'\033[0m'
		warn=$'\033[38;5;220m'
	fi
	printf '%b[WARN]%b %s\n' "$warn" "$reset" "$*"
}

log_error() {
	local reset="" err=""
	if supports_color; then
		reset=$'\033[0m'
		err=$'\033[38;5;203m'
	fi
	printf '%b[ERROR]%b %s\n' "$err" "$reset" "$*" >&2
}

fail() {
	log_error "$*"
	exit 1
}

require_file() {
	local file="$1"
	[[ -f "$file" ]] || fail "Required file not found: $file"
}

require_exec() {
	local file="$1"
	[[ -x "$file" ]] || fail "Required executable not found: $file"
}

run_compose() {
	command -v docker >/dev/null 2>&1 || fail "docker command not found"
	require_file "$COMPOSE_FILE"
	docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

run_env_check() {
	require_exec "$CHECK_ENV_SCRIPT"
	"$CHECK_ENV_SCRIPT" --env-file "$ENV_FILE" "$@"
}

run_deps_check() {
	require_exec "$CHECK_DEPS_SCRIPT"
	"$CHECK_DEPS_SCRIPT" --env-file "$ENV_FILE" "$@"
}

generate_secure_hex_key() {
	local key=""
	if command -v openssl >/dev/null 2>&1; then
		key="$(openssl rand -hex 32 | tr -d '\n')"
	elif [[ -r /dev/urandom ]]; then
		key="$(od -An -N32 -tx1 /dev/urandom | tr -d ' \n')"
	else
		fail "Cannot generate key: neither openssl nor /dev/urandom is available"
	fi

	[[ "${#key}" -ge 64 ]] || fail "Generated key is too short"
	printf '%s' "$key"
}

backup_timestamp() {
	date '+%Y-%m-%d_%H-%M-%S'
}

next_backup_path() {
	local target="$1"
	local timestamp backup_path counter

	timestamp="$(backup_timestamp)"
	backup_path="${target}.bak.${timestamp}"
	counter=0

	while [[ -e "$backup_path" || -L "$backup_path" ]]; do
		counter=$((counter + 1))
		backup_path="${target}.bak.${timestamp}.${counter}"
	done

	printf '%s' "$backup_path"
}

backup_existing_path() {
	local target="$1"
	local backup_path=""

	if [[ -e "$target" || -L "$target" ]]; then
		backup_path="$(next_backup_path "$target")"
		cp -a "$target" "$backup_path"
	fi

	printf '%s' "$backup_path"
}

replace_file_with_copy() {
	local source="$1"
	local target="$2"
	local target_dir temp_path

	target_dir="$(dirname "$target")"
	temp_path="$target_dir/.tmp.$(basename "$target").$$"
	cp "$source" "$temp_path"
	mv -f "$temp_path" "$target"
}

env_file_has_key() {
	local file="$1"
	[[ -f "$file" ]] || return 1
	grep -q '^N8N_ENCRYPTION_KEY=' "$file"
}

normalize_protocol_value() {
	local value="$1"
	value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')"
	printf '%s' "$value"
}

default_nginx_conf_name() {
	local domain="$1"
	local conf_name="${domain//./-}"
	printf '%s' "${conf_name:-n8n}"
}

set_env_var() {
	local file="$1"
	local key="$2"
	local value="$3"
	local escaped_value=""

	[[ -f "$file" ]] || fail "Env file not found: $file"
	escaped_value="$(printf '%s' "$value" | sed 's/[&|]/\\&/g')"

	if grep -q "^${key}=" "$file"; then
		sed -i "s|^${key}=.*$|${key}=${escaped_value}|" "$file"
	else
		printf '\n%s=%s\n' "$key" "$value" >>"$file"
	fi
}

set_env_key() {
	local file="$1"
	local key="$2"
	local force="$3"

	[[ -f "$file" ]] || fail "Env file not found: $file"

	if env_file_has_key "$file"; then
		[[ "$force" -eq 1 ]] || fail "N8N_ENCRYPTION_KEY already exists in $file (use --force to replace)"
		set_env_var "$file" "N8N_ENCRYPTION_KEY" "$key"
	else
		set_env_var "$file" "N8N_ENCRYPTION_KEY" "$key"
	fi
}

populate_initialized_env() {
	local file="$1"
	local encryption_key admin_password app_password

	encryption_key="$(generate_secure_hex_key)"
	admin_password="$(generate_secure_hex_key)"
	app_password="$(generate_secure_hex_key)"

	set_env_var "$file" "N8N_ENCRYPTION_KEY" "$encryption_key"
	set_env_var "$file" "POSTGRES_USER" "n8n_admin"
	set_env_var "$file" "POSTGRES_PASSWORD" "$admin_password"
	set_env_var "$file" "POSTGRES_NON_ROOT_USER" "n8n_user"
	set_env_var "$file" "POSTGRES_NON_ROOT_PASSWORD" "$app_password"
}

find_backups_for_target() {
	local target="$1"
	local search_dir base_name

	search_dir="$(dirname "$target")"
	base_name="$(basename "$target")"
	[[ -d "$search_dir" ]] || return 0

	find "$search_dir" -maxdepth 1 \( -type f -o -type l \) -name "${base_name}.bak.*" | sort -r
}

prompt_for_backup_selection() {
	local label="$1"
	shift
	local backups=("$@")
	local choice="" index=0

	((${#backups[@]} > 0)) || fail "No backups available for ${label}"

	printf 'Available backups for %s:\n' "$label" >&2
	while ((index < ${#backups[@]})); do
		printf '  %d) %s\n' "$((index + 1))" "${backups[$index]}" >&2
		index=$((index + 1))
	done

	read -r -p "Select backup to restore [1-${#backups[@]}] (Enter=1): " choice
	choice="${choice:-1}"
	[[ "$choice" =~ ^[0-9]+$ ]] || fail "Invalid backup selection: $choice"
	index=$((choice - 1))
	((index >= 0 && index < ${#backups[@]})) || fail "Backup selection out of range: $choice"
	printf '%s' "${backups[$index]}"
}

cmd_env_init() {
	local profile="prod"
	local force=0
	local template=""
	local previous_backup=""

	while (($# > 0)); do
		case "$1" in
			local)
				profile="local"
				shift
				;;
			prod|production)
				profile="prod"
				shift
				;;
			--force|-f)
				force=1
				shift
				;;
			--target|-t)
				fail "env init no longer accepts --target. It now always creates or replaces $ENV_FILE"
				;;
			-h|--help)
				cat <<'EOF'
Usage:
  ./n8nite env init [local|prod] [--force]

Defaults:
  profile: prod
  target:  <repo>/.env
EOF
				return 0
				;;
			*)
				fail "Unknown env init argument: $1"
				;;
		esac
	done

	if [[ "$profile" == "local" ]]; then
		template="$ENV_TEMPLATE_LOCAL"
	else
		template="$ENV_TEMPLATE_PROD"
	fi

	require_file "$template"

	if [[ ( -e "$ENV_FILE" || -L "$ENV_FILE" ) && "$force" -ne 1 ]]; then
		fail "Env file already exists: $ENV_FILE (use --force to overwrite)"
	fi

	if [[ -e "$ENV_FILE" || -L "$ENV_FILE" ]]; then
		previous_backup="$(backup_existing_path "$ENV_FILE")"
	fi

	replace_file_with_copy "$template" "$ENV_FILE"
	log "Created env file from template '$profile': $ENV_FILE"
	log "Generating N8N_ENCRYPTION_KEY and PostgreSQL credentials for $ENV_FILE"
	populate_initialized_env "$ENV_FILE"
	log "Initialized database users: POSTGRES_USER=n8n_admin, POSTGRES_NON_ROOT_USER=n8n_user"
	if [[ -n "$previous_backup" ]]; then
		log "Previous env snapshot preserved at $previous_backup"
	fi
	if [[ "$profile" == "prod" ]]; then
		log "Production init keeps your domain placeholders on purpose. Update N8N_HOST and WEBHOOK_URL before validation."
	else
		log "Local init is ready for validation with the generated secrets."
	fi
	log "Restore a prior env snapshot with: ./n8nite env restore"
	log "Next: ./n8nite env check"
}

cmd_env_select() {
	local source=""
	local previous_backup=""

	while (($# > 0)); do
		case "$1" in
			-h|--help)
				cat <<'EOF'
Usage:
  ./n8nite env select PATH

Copies PATH into the repository .env file and keeps a timestamped backup of the
previous .env when one already exists.
EOF
				return 0
				;;
			*)
				if [[ -z "$source" ]]; then
					source="$1"
					shift
				else
					fail "Unknown env select argument: $1"
				fi
				;;
		esac
	done

	[[ -n "$source" ]] || fail "env select requires a source file path"
	require_file "$source"

	if [[ ( -e "$ENV_FILE" || -L "$ENV_FILE" ) && "$source" -ef "$ENV_FILE" ]]; then
		log "Repo env file is already up to date: $ENV_FILE"
		return 0
	fi

	if [[ -e "$ENV_FILE" || -L "$ENV_FILE" ]]; then
		previous_backup="$(backup_existing_path "$ENV_FILE")"
	fi

	replace_file_with_copy "$source" "$ENV_FILE"
	log "Copied selected env file into $ENV_FILE from $source"
	if [[ -n "$previous_backup" ]]; then
		log "Previous env snapshot preserved at $previous_backup"
	fi
	log "Next: ./n8nite env check"
}

cmd_env_restore() {
	local backup_path=""
	local latest=0
	local assume_yes=0
	local selection=""
	local current_backup=""
	local backups=()

	while (($# > 0)); do
		case "$1" in
			--backup|-b)
				backup_path="${2:-}"
				shift 2
				;;
			--latest)
				latest=1
				shift
				;;
			--yes|-y)
				assume_yes=1
				shift
				;;
			-h|--help)
				cat <<'EOF'
Usage:
  ./n8nite env restore [--backup PATH|--latest] [--yes]

Options:
  -b, --backup PATH  Restore a specific backup file
      --latest       Restore the newest timestamped backup for the env file
  -y, --yes          Skip confirmation prompt
EOF
				return 0
				;;
			*)
				fail "Unknown env restore argument: $1"
				;;
		esac
	done

	if [[ -n "$backup_path" && "$latest" -eq 1 ]]; then
		fail "Use either --backup or --latest for env restore"
	fi

	if [[ -n "$backup_path" ]]; then
		[[ -e "$backup_path" || -L "$backup_path" ]] || fail "Env backup not found: $backup_path"
		selection="$backup_path"
	else
		mapfile -t backups < <(find_backups_for_target "$ENV_FILE")
		((${#backups[@]} > 0)) || fail "No env backups found for $ENV_FILE"
		if [[ "$latest" -eq 1 ]]; then
			selection="${backups[0]}"
			log "Using latest env backup: $selection"
		else
			selection="$(prompt_for_backup_selection "$ENV_FILE" "${backups[@]}")"
		fi
	fi

	if [[ "$assume_yes" -ne 1 ]]; then
		if ! confirm_yes_no "Restore env backup $selection to $ENV_FILE?"; then
			log "Keeping current env file, restore skipped."
			return 0
		fi
	fi

	if [[ -e "$ENV_FILE" || -L "$ENV_FILE" ]]; then
		current_backup="$(backup_existing_path "$ENV_FILE")"
	fi

	replace_file_with_copy "$selection" "$ENV_FILE"
	log "Restored env file from $selection to $ENV_FILE"
	if [[ -n "$current_backup" ]]; then
		log "Current env file was backed up before restore: $current_backup"
	fi
	log "Next: ./n8nite env check"
}

cmd_env_keygen() {
	local write=0
	local force=0
	local plain=0
	local key=""

	while (($# > 0)); do
		case "$1" in
			--write|-w)
				write=1
				shift
				;;
			--force|-f)
				force=1
				shift
				;;
			--plain|-p)
				plain=1
				shift
				;;
			-h|--help)
				cat <<'EOF'
Usage:
  ./n8nite env keygen [--write] [--force] [--plain]

Options:
  -w, --write    Write generated key to N8N_ENCRYPTION_KEY in env file
  -f, --force    Replace existing N8N_ENCRYPTION_KEY when used with --write
  -p, --plain    Print raw key only (without N8N_ENCRYPTION_KEY= prefix)
EOF
				return 0
				;;
			*)
				fail "Unknown env keygen argument: $1"
				;;
		esac
	done

	key="$(generate_secure_hex_key)"

	if [[ "$write" -eq 1 ]]; then
		set_env_key "$ENV_FILE" "$key" "$force"
		log "Updated N8N_ENCRYPTION_KEY in $ENV_FILE"
	fi

	if [[ "$plain" -eq 1 ]]; then
		printf '%s\n' "$key"
	else
		printf 'N8N_ENCRYPTION_KEY=%s\n' "$key"
	fi
}

cmd_env_view() {
	while (($# > 0)); do
		case "$1" in
			-h|--help)
				cat <<'EOF'
Usage:
  ./n8nite env view

View env file content.
Viewer preference:
  1) nano -v
  2) less
  3) cat
EOF
				return 0
				;;
			*)
				fail "Unknown env view argument: $1"
				;;
		esac
	done

	[[ -f "$ENV_FILE" ]] || fail "Env file not found: $ENV_FILE"

	if command -v nano >/dev/null 2>&1; then
		if nano -v "$ENV_FILE"; then
			return 0
		fi
		log_warn "nano -v exited with error; trying less."
	fi

	if command -v less >/dev/null 2>&1; then
		LESS="${LESS:--FRX}" less "$ENV_FILE"
	else
		log_warn "'less' not found; printing with cat."
		cat "$ENV_FILE"
	fi
}

cmd_env_edit() {
	while (($# > 0)); do
		case "$1" in
			-h|--help)
				cat <<'EOF'
Usage:
  ./n8nite env edit

Open env file in an editor.
Editor preference:
  1) nano
  2) vi (with syntax commands)
EOF
				return 0
				;;
			*)
				fail "Unknown env edit argument: $1"
				;;
		esac
	done

	if [[ ! -e "$ENV_FILE" ]]; then
		log_warn "Env file not found, creating: $ENV_FILE"
		touch "$ENV_FILE"
	fi

	if command -v nano >/dev/null 2>&1; then
		if nano "$ENV_FILE"; then
			return 0
		fi
		log_warn "nano exited with error; falling back to vi."
	fi

	if command -v vi >/dev/null 2>&1; then
		# Try enabling shell syntax highlighting in vi/vim; fallback to plain vi on unsupported flags.
		if vi -c 'syntax on' -c 'set filetype=sh' "$ENV_FILE"; then
			return 0
		fi
		vi "$ENV_FILE"
		return $?
	fi

	fail "No supported editor found (install nano or vi)"
}

cmd_env() {
	local subcommand="${1:-check}"
	if [[ $# -gt 0 ]]; then
		shift
	fi

	case "$subcommand" in
		check)
			run_env_check "$@"
			;;
		init)
			cmd_env_init "$@"
			;;
		select)
			cmd_env_select "$@"
			;;
		restore)
			cmd_env_restore "$@"
			;;
		view)
			cmd_env_view "$@"
			;;
		edit)
			cmd_env_edit "$@"
			;;
		keygen)
			cmd_env_keygen "$@"
			;;
		*)
			fail "Unknown env subcommand: $subcommand"
			;;
	esac
}

cmd_deps() {
	local subcommand="${1:-check}"
	if [[ $# -gt 0 ]]; then
		shift
	fi

	case "$subcommand" in
		check)
			run_deps_check "$@"
			;;
		-h|--help|help)
			run_deps_check --help
			;;
		*)
			fail "Unknown deps subcommand: $subcommand"
			;;
	esac
}

cmd_nginx() {
	local subcommand="${1:-}"
	if [[ $# -gt 0 ]]; then
		shift
	fi

	case "$subcommand" in
		generate)
			require_exec "$NGINX_GENERATE_SCRIPT"
			"$NGINX_GENERATE_SCRIPT" "$@"
			;;
		deploy)
			require_exec "$NGINX_DEPLOY_SCRIPT"
			"$NGINX_DEPLOY_SCRIPT" --env-file "$ENV_FILE" "$@"
			;;
		restore)
			require_exec "$NGINX_RESTORE_SCRIPT"
			"$NGINX_RESTORE_SCRIPT" --env-file "$ENV_FILE" "$@"
			;;
		*)
			fail "Unknown nginx subcommand: ${subcommand:-<empty>} (use: generate|deploy|restore)"
			;;
	esac
}

cmd_uninstall() {
	local bin_dir="${N8N_SH_BIN_DIR:-$HOME/.local/bin}"
	local bin_name="${N8N_SH_BIN_NAME:-n8nite}"
	local target=""
	local assume_yes=0

	while (($# > 0)); do
		case "$1" in
			--bin-dir)
				bin_dir="${2:-}"
				shift 2
				;;
			--bin-name)
				bin_name="${2:-}"
				shift 2
				;;
			-y|--yes)
				assume_yes=1
				shift
				;;
			-h|--help)
				cat <<'EOF'
Usage:
  ./n8nite uninstall [--yes] [--bin-dir PATH] [--bin-name NAME]

Options:
  -y, --yes          Skip confirmation prompt
      --bin-dir      Symlink directory (default: ~/.local/bin or N8N_SH_BIN_DIR)
      --bin-name     Command name (default: n8nite or N8N_SH_BIN_NAME)
EOF
				return 0
				;;
			*)
				fail "Unknown uninstall argument: $1"
				;;
		esac
	done

	target="$bin_dir/$bin_name"

	if [[ ! -e "$target" && ! -L "$target" ]]; then
		log "No installed command symlink at $target"
		return 0
	fi

	[[ -L "$target" ]] || fail "Refusing to remove non-symlink path: $target"

	if [[ "$assume_yes" -ne 1 ]]; then
		if ! confirm_yes_no "Remove installed symlink $target?"; then
			log "Aborted"
			return 0
		fi
	fi

	rm -f "$target"
	log "Removed symlink: $target"
}

prompt_default() {
	local label="$1"
	local default_value="${2:-}"
	local value=""
	if [[ -n "$default_value" ]]; then
		read -r -p "$label [$default_value]: " value
		printf '%s' "${value:-$default_value}"
	else
		read -r -p "$label: " value
		printf '%s' "$value"
	fi
}

confirm_yes_no() {
	local label="$1"
	local answer=""
	read -r -p "$label [y/N]: " answer
	[[ "$answer" =~ ^[Yy]([Ee][Ss])?$ ]]
}

run_step() {
	local label="$1"
	shift
	local reset="" run="" ok="" fail_color=""
	if supports_color; then
		reset=$'\033[0m'
		run=$'\033[38;5;118m'
		ok=$'\033[38;5;78m'
		fail_color=$'\033[38;5;203m'
	fi

	printf '\n%b[RUN]%b %s\n' "$run" "$reset" "$label"
	if "$@"; then
		printf '%b[OK]%b %s\n' "$ok" "$reset" "$label"
		return 0
	fi
	local rc=$?
	printf '%b[FAIL]%b %s (exit %d)\n' "$fail_color" "$reset" "$label" "$rc" >&2
	return "$rc"
}

get_env_value() {
	local file="$1"
	local key="$2"
	[[ -f "$file" ]] || return 0
	(
		set -a
		# shellcheck disable=SC1090
		source "$file" >/dev/null 2>&1 || true
		eval "printf '%s' \"\${$key:-}\""
	)
}

interactive_nginx_generate() {
	local default_mode default_server mode server
	local args=()

	default_mode="$(normalize_protocol_value "$(get_env_value "$ENV_FILE" "N8N_PROTOCOL")")"
	if [[ "$default_mode" != "http" && "$default_mode" != "https" && "$default_mode" != "both" ]]; then
		default_mode="https"
	fi
	default_server="$(get_env_value "$ENV_FILE" "N8N_HOST")"
	default_server="${default_server:-localhost}"

	mode="$default_mode"
	server="$default_server"
	args=(-m "$mode" -s "$server")

	log "Using nginx generate defaults: mode=$mode, server=$server, upstream=127.0.0.1:5678, out_dir=$REPO_ROOT/nginx/generated"
	run_step "nginx generate (${mode})" "$NGINX_GENERATE_SCRIPT" "${args[@]}" || true
}

interactive_nginx_deploy() {
	local domain default_conf
	domain="$(get_env_value "$ENV_FILE" "N8N_HOST")"
	default_conf="$(default_nginx_conf_name "$domain")"
	log "Using nginx deploy defaults: conf=$default_conf, upstream=127.0.0.1:5678"
	run_step "nginx deploy" "$NGINX_DEPLOY_SCRIPT" --env-file "$ENV_FILE" || true
}

interactive_env_init() {
	local profile="$1"
	local force_flag=()

	if [[ -e "$ENV_FILE" || -L "$ENV_FILE" ]]; then
		if confirm_yes_no "Overwrite current .env file ($ENV_FILE)?"; then
			force_flag=(--force)
		else
			log "Keeping existing .env file, skipping env init."
			return 0
		fi
	fi

	run_step "env init (${profile})" cmd_env_init "$profile" "${force_flag[@]}" || true
}

interactive_env_select() {
	local source=""

	source="$(prompt_default "Source env file path to copy into $ENV_FILE" "")"
	if [[ -z "$source" ]]; then
		log "No env source provided, skipping env select."
		return 0
	fi

	run_step "env select" cmd_env_select "$source" || true
}

interactive_keygen() {
	local args=()
	if confirm_yes_no "Write key into current env file ($ENV_FILE)?"; then
		args+=(--write)
		if env_file_has_key "$ENV_FILE"; then
			if confirm_yes_no "Replace existing key in $ENV_FILE?"; then
				args+=(--force)
			else
				log "Keeping existing N8N_ENCRYPTION_KEY in $ENV_FILE."
				return 0
			fi
		fi
	fi
	run_step "env keygen" cmd_env_keygen "${args[@]}" || true
}

interactive_logs() {
	local service follow="n" cmd=(logs --tail=200)
	service="$(prompt_default "Service name (blank for all)" "")"
	if confirm_yes_no "Follow logs in real time?"; then
		follow="y"
		cmd=(logs --tail=200 -f)
	fi
	[[ -n "$service" ]] && cmd+=("$service")

	if [[ "$follow" == "y" ]]; then
		printf '\n'
		log "Press Ctrl+C to stop log streaming and return to menu."
	fi
	run_step "docker compose logs" run_compose "${cmd[@]}" || true
}

interactive_view_env_file() {
	cmd_env_view
}

interactive_edit_env_file() {
	cmd_env_edit
}

print_interactive_menu() {
	local reset="" title="" section=""
	if supports_color; then
		reset=$'\033[0m'
		title=$'\033[38;5;118m'
		section=$'\033[38;5;118m'
	fi

	printf '\n%b=== n8nite Interactive Menu ===%b\n' "$title" "$reset"
	printf '%bEnv file:%b %s\n' "$section" "$reset" "$ENV_FILE"
	printf '%b----------------------------------------%b\n' "$section" "$reset"
	printf '%bEnvironment%b\n' "$section" "$reset"
	printf '  1) Select .env file\n'
	printf '  2) Check .env file\n'
	printf '  3) Initialize .env file (local)\n'
	printf '  4) Initialize .env file (production)\n'
	printf '  5) Generate N8N key\n'
	printf '  6) Edit .env file\n'
	printf '  7) View .env file\n'
	printf '%bStack%b\n' "$section" "$reset"
	printf '  8) Stack up\n'
	printf '  9) Stack down\n'
	printf '  10) Stack restart\n'
	printf '  11) Stack status (ps)\n'
	printf '  12) Stack logs\n'
	printf '%bNginx%b\n' "$section" "$reset"
	printf '  13) Nginx generate\n'
	printf '  14) Nginx deploy\n'
	printf '%bDiagnostics%b\n' "$section" "$reset"
	printf '  15) Deps check\n'
	printf '  16) Test suite (functional)\n'
	printf '  17) Test suite (requirements)\n'
	printf '  18) Doctor\n'
	printf '  0) Exit\n'
}

interactive_menu() {
	local choice=""

	print_banner

	while true; do
		print_interactive_menu
		read -r -p "Choose an action [0-18]: " choice

		case "$choice" in
			1)
				interactive_env_select
				;;
			2)
				run_step "env check" run_env_check || true
				;;
			3)
				interactive_env_init "local"
				;;
			4)
				interactive_env_init "prod"
				;;
			5)
				interactive_keygen
				;;
			6)
				interactive_edit_env_file
				;;
			7)
				interactive_view_env_file
				;;
			8)
				run_step "stack up" run_env_check && run_step "docker compose up -d" run_compose up -d || true
				;;
			9)
				run_step "docker compose down" run_compose down || true
				;;
			10)
				run_step "docker compose restart" run_compose restart || true
				;;
			11)
				run_step "docker compose ps" run_compose ps || true
				;;
			12)
				interactive_logs
				;;
			13)
				interactive_nginx_generate
				;;
			14)
				interactive_nginx_deploy
				;;
			15)
				run_step "deps check" run_deps_check || true
				;;
			16)
				run_step "test suite (functional)" "$TEST_SUITE_SCRIPT" -f || true
				;;
			17)
				run_step "test suite (requirements)" "$TEST_SUITE_SCRIPT" -r || true
				;;
			18)
				run_step "doctor" run_env_check && run_step "docker compose ps" run_compose ps || true
				;;
			0)
				log "Exiting interactive mode."
				break
				;;
			*)
				log_error "Invalid option: $choice"
				;;
		esac
	done
}

while (($# > 0)); do
	case "$1" in
		-v|--version)
			print_banner
			print_version
			exit 0
			;;
		-h|--help)
			print_banner
			usage
			exit 0
			;;
		--)
			shift
			break
			;;
		--env-file|-e)
			fail "The global --env-file override was removed. Use './n8nite env select PATH' or './n8nite env init ...' to update $ENV_FILE"
			;;
		*)
			break
			;;
	esac
done

command="${1:-help}"
if [[ $# -gt 0 ]]; then
	shift
fi

case "$command" in
	help|-h|--help)
		print_banner
		usage
		;;
	env)
		cmd_env "$@"
		;;
	deps)
		cmd_deps "$@"
		;;
	up)
		run_env_check
		run_compose up -d "$@"
		;;
	down)
		run_compose down "$@"
		;;
	start)
		run_compose start "$@"
		;;
	stop)
		run_compose stop "$@"
		;;
	restart)
		run_compose restart "$@"
		;;
	logs)
		run_compose logs --tail=200 -f "$@"
		;;
	ps|status)
		run_compose ps "$@"
		;;
	config)
		run_compose config "$@"
		;;
	pull)
		run_compose pull "$@"
		;;
	nginx)
		cmd_nginx "$@"
		;;
	uninstall)
		cmd_uninstall "$@"
		;;
	interactive|i)
		interactive_menu
		;;
	test)
		require_exec "$TEST_SUITE_SCRIPT"
		"$TEST_SUITE_SCRIPT" "$@"
		;;
	doctor)
		run_env_check
		run_compose ps
		;;
	*)
		fail "Unknown command: $command (run ./n8nite --help)"
		;;
esac
